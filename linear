import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_squared_error, r2_score
from sklearn.datasets import fetch_openml

x_simple = np.array([95, 85, 80, 70, 60])
y_simple = np.array([85, 95, 70, 65, 70])

model_simple = np.polyfit(x_simple, y_simple, 1)
predict_func = np.poly1d(model_simple)
y_pred_simple = predict_func(x_simple)

print("--- Synthesis Dataset Results ---")
print(f"Coefficients: {model_simple}")
print(f"Prediction for 65: {predict_func(65):.2f}")
print(f"R2 Score: {r2_score(y_simple, y_pred_simple):.4f}")

plt.figure(figsize=(12, 5))
plt.subplot(1, 2, 1)
plt.scatter(x_simple, y_simple, c='red', label='Actual')
plt.plot(x_simple, model_simple[1] + model_simple[0]*x_simple, c='blue', label='Regression Line')
plt.title("Synthesis Dataset")
plt.legend()

boston = fetch_openml(name='boston', version=1, as_frame=True)
df = boston.frame

X = df.drop(['MEDV'], axis=1)
y = df['MEDV']

X = X.astype(float)
y = y.astype(float) # Also ensure target is float for consistency

xtrain, xtest, ytrain, ytest = train_test_split(X, y, test_size=0.2, random_state=0)

lm = LinearRegression()
lm.fit(xtrain, ytrain)

ytrain_pred = lm.predict(xtrain)
ytest_pred = lm.predict(xtest)

print("\n--- Boston Dataset Results ---")
print(f"Mean Squared Error (Test): {mean_squared_error(ytest, ytest_pred):.4f}")
print(f"Mean Squared Error (Train): {mean_squared_error(ytrain, ytrain_pred):.4f}")

plt.subplot(1, 2, 2)
plt.scatter(ytrain, ytrain_pred, c='blue', marker='o', label='Training data')
plt.scatter(ytest, ytest_pred, c='lightgreen', marker='s', label='Test data')
plt.xlabel('True values')
plt.ylabel('Predicted')
plt.title("True vs Predicted (Boston)")
plt.legend()
plt.tight_layout()
plt.show()
